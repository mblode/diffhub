{
  "name": "diffhub",
  "version": "0.1.1",
  "description": "GitHub PR-style local diff viewer — review your git changes in the browser",
  "keywords": [
    "ai",
    "cli",
    "code-review",
    "diff",
    "git",
    "github",
    "pr"
  ],
  "homepage": "https://github.com/mblode/diffhub#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mblode/diffhub"
  },
  "bin": {
    "diffhub": "./bin/diffhub.mjs"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    "package.json"
  ],
  "scripts": {
    "dev": "portless run --force next dev",
    "build": "next build",
    "prepack": "next build && cp -r .next/static .next/standalone/apps/web/.next/static",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "next build && cp -r .next/static .next/standalone/apps/web/.next/static && changeset publish"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@pierre/diffs": "^1.1.15",
    "agentation": "^3.0.2",
    "blode-icons-react": "^0.3.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "lefthook": "^2.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "portless": "^0.10.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "ultracite": "^7.5.6"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2",
    "@tailwindcss/oxide-linux-arm64-gnu": "4.2.2",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-linux-arm64-gnu": "1.32.0"
  },
  "engines": {
    "node": ">=18"
  }
}
