{
  "name": "diffhub",
  "version": "0.3.2",
  "description": "GitHub PR-style local diff viewer — review your git changes in the browser",
  "keywords": [
    "ai",
    "cli",
    "code-review",
    "diff",
    "git",
    "github",
    "pr"
  ],
  "homepage": "https://github.com/mblode/diffhub#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mblode/diffhub"
  },
  "bin": {
    "diffhub": "./bin/diffhub.mjs"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    "package.json"
  ],
  "type": "module",
  "scripts": {
    "dev": "portless run --force next dev",
    "build": "next build",
    "prepare:standalone": "node ./bin/prepare-standalone.mjs",
    "prepack": "next build && npm run prepare:standalone",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "check-types": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "next build && npm run prepare:standalone && changeset publish"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@changesets/cli": "^2.31.0",
    "@diffhub/diff-core": "*",
    "@pierre/diffs": "^1.2.12",
    "@pierre/trees": "^1.0.0-beta.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agentation": "^3.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "blode-icons-react": "^0.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "portless": "^0.15.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "ultracite": "7.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "bun": ">=1.0.23",
    "node": ">=20.11"
  }
}
