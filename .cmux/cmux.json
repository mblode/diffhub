{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "commands": [
    {
      "name": "Dev + Preview",
      "description": "turbo dev (cli + web) beside the local previews",
      "keywords": ["dev", "preview", "diffhub", "web"],
      "workspace": {
        "name": "diffhub",
        "cwd": ".",
        "color": "#5E6AD2",
        "layout": {
          "direction": "horizontal",
          "split": 0.55,
          "children": [
            {
              "pane": {
                "surfaces": [
                  { "type": "terminal", "name": "Dev", "command": "npm run dev" }
                ]
              }
            },
            {
              "pane": {
                "surfaces": [
                  { "type": "browser", "name": "App", "url": "https://diffhub.localhost" },
                  { "type": "browser", "name": "Web", "url": "https://diffhub-web.localhost" }
                ]
              }
            }
          ]
        }
      }
    }
  ]
}
